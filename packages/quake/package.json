    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "devDependencies": {
    "@qltracker/eslint-config": "workspace:*",
    "@qltracker/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.4",
    "typescript": "^5.9.3"
  }
}
