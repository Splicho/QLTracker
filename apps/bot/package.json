{
  "name": "@qltracker/bot",
  "version": "0.1.0",
  "private": true,
  "description": "Lightweight Discord bot scaffold for Quake Live tracking.",
  "type": "module",
  "engines": {
    "node": ">=20.11"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "lint": "eslint src --ext .ts",
    "register:commands": "tsx src/scripts/register-commands.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "discord",
    "discord.js",
    "typescript",
    "slash-commands",
    "quake-live"
  ],
  "license": "UNLICENSED",
  "dependencies": {
    "@qltracker/config": "workspace:*",
    "@qltracker/contracts": "workspace:*",
    "@qltracker/crypto": "workspace:*",
    "discord.js": "^14.26.2",
    "dotenv": "^17.4.1",
    "pino": "^10.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@qltracker/eslint-config": "workspace:*",
    "@qltracker/typescript-config": "workspace:*",
    "@types/node": "^25.5.2",
    "eslint": "^9.39.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
