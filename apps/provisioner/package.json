    "express": "^5.1.0",
    "zeromq": "^5.3.1",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@qltracker/eslint-config": "workspace:*",
    "@qltracker/typescript-config": "workspace:*",
    "@types/express": "^5.0.3",
    "@types/node": "^24.7.2",
    "eslint": "^9.39.4",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
