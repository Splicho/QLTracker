{
  "name": "@qltracker/provisioner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "start": "node dist/index.js",
    "check": "tsc --noEmit -p tsconfig.json",
